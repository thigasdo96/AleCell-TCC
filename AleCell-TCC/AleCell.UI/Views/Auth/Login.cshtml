@model LoginVM
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <div class="auth-container">
        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors" hidden></div>
            <div class="auth-header">
                <span class="logo" style="font-size:2rem">ALECELL</span>
                <h2>Entrar na Conta</h2>
                <p>Acesse sua conta para comprar e acompanhar pedidos</p>
            </div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" placeholder="seu@@email.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Senha"></label>
                <input asp-for="Senha" type="password" placeholder="Sua senha" autocomplete="current-password" />
                <span asp-validation-for="Senha" class="field-error"></span>
            </div>
            <button type="submit" class="btn btn-grande" style="width:100%;margin-top:.5rem">Entrar</button>
            <div class="auth-footer">
                <p>Não tem conta? <a asp-controller="Auth" asp-action="Registro">Cadastre-se grátis</a></p>
            </div>
            <div class="credenciais-teste">
                <h4>Credenciais de Teste</h4>
                <div class="cred-item"><strong>Admin:</strong> <code>admin@@alecell.com.br</code> / <code>Admin@123</code></div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
