@model RegistroVM
@{
    ViewData["Title"] = "Criar Conta";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <div class="auth-container">
        <form asp-action="Registro" method="post" enctype="multipart/form-data" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors" hidden></div>
            <div class="auth-header">
                <span class="logo" style="font-size:2rem">ALECELL</span>
                <h2>Criar Conta</h2>
                <p>Cadastre-se para comprar e acompanhar seus pedidos</p>
            </div>
            <div class="form-group">
                <label asp-for="Nome"></label>
                <input asp-for="Nome" placeholder="Seu nome completo" />
                <span asp-validation-for="Nome" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" placeholder="seu@@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Senha"></label>
                <input asp-for="Senha" type="password" placeholder="Mínimo 6 caracteres" />
                <span asp-validation-for="Senha" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="DataNascimento"></label>
                <input asp-for="DataNascimento" type="date" />
            </div>
            <button type="submit" class="btn btn-grande" style="width:100%;margin-top:.5rem">Criar Conta</button>
            <div class="auth-footer">
                <p>Já possui uma conta? <a asp-controller="Auth" asp-action="Login">Entre aqui</a></p>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
