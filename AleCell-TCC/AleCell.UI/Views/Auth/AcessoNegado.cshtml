@{
    ViewData["Title"] = "Acesso Negado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <div class="auth-container">
        <div class="auth-form" style="text-align:center">
            <div style="margin-bottom:1.25rem">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#ff5252" stroke-width="1.5" style="margin:0 auto">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="15" y1="9" x2="9" y2="15"/>
                    <line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
            </div>
            <h2 style="font-family:'Orbitron',sans-serif;color:var(--texto);margin-bottom:.75rem">Acesso Negado</h2>
            <p style="color:var(--texto-muted);margin:0 0 1.5rem">Você não tem permissão para acessar essa área.</p>
            <div style="display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap">
                <a asp-controller="Home" asp-action="Index" class="btn">Voltar para a Loja</a>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline">Fazer Login</a>
            </div>
        </div>
    </div>
</section>
