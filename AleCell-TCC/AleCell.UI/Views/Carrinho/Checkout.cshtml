@model List<CarrinhoItemDto>
@{
    ViewData["Title"] = "Finalizar Compra";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var total = Model.Sum(i => i.Subtotal);
}

<section class="container">
    <nav class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>›</span>
        <a asp-controller="Carrinho" asp-action="Index">Carrinho</a>
        <span>›</span>
        <span>Checkout</span>
    </nav>

    <div class="page-header">
        <h1 class="page-titulo">Finalizar Compra</h1>
    </div>

    <div class="checkout-layout">

        <!-- FORMULÁRIO -->
        <div class="checkout-form-area">
            <form id="formCheckout" asp-controller="Carrinho" asp-action="FinalizarPedido" method="post" novalidate>
                @Html.AntiForgeryToken()
                <!-- campo oculto para forma de pagamento -->
                <input type="hidden" id="formaPagamentoHidden" name="formaPagamento" value="Cartão" />

                <!-- DADOS PESSOAIS -->
                <div class="admin-card" style="padding:1.5rem;margin-bottom:1.25rem">
                    <h3 style="margin-bottom:1.25rem;color:var(--primario);font-size:1rem">Dados de Entrega</h3>

                    <div class="form-grid-2">
                        <div class="form-grupo">
                            <label class="form-label" for="nome">Nome Completo *</label>
                            <input type="text" id="nome" name="nome" class="form-input" required
                                   minlength="3"
                                   value="@User.Identity?.Name"
                                   placeholder="Seu nome completo" />
                            <span class="campo-erro" id="erroNome"></span>
                        </div>

                        <div class="form-grupo">
                            <label class="form-label" for="email">E-mail *</label>
                            <input type="email" id="email" name="email" class="form-input" required
                                   placeholder="seu@@email.com"
                                   autocomplete="email" />
                            <span class="campo-erro" id="erroEmail"></span>
                        </div>

                        <div class="form-grupo">
                            <label class="form-label" for="telefone">Telefone *</label>
                            <input type="tel" id="telefone" name="telefone" class="form-input" required
                                   placeholder="(14) 9 9999-9999"
                                   maxlength="16"
                                   autocomplete="tel" />
                            <span class="campo-erro" id="erroTelefone"></span>
                        </div>

                        <div class="form-grupo">
                            <label class="form-label" for="cep">CEP</label>
                            <input type="text" id="cep" name="cep" class="form-input"
                                   placeholder="00000-000" maxlength="9" />
                        </div>
                    </div>

                    <div class="form-grupo">
                        <label class="form-label" for="endereco">Endereço Completo *</label>
                        <input type="text" id="endereco" name="endereco" class="form-input" required
                               placeholder="Rua, número, bairro, cidade - UF" />
                        <span class="campo-erro" id="erroEndereco"></span>
                    </div>
                </div>

                <!-- PARCELAMENTO -->
                <div class="admin-card" style="padding:1.5rem;margin-bottom:1.25rem">
                    <h3 style="margin-bottom:1.25rem;color:var(--primario);font-size:1rem">Parcelamento</h3>
                    <div class="parcelas-grid">
                        @for (int p = 1; p <= 12; p++)
                        {
                            decimal valorParcela = total / p;
                            <label class="parcela-opcao">
                                <input type="radio" name="parcelas" value="@p" @(p == 1 ? "checked" : "") />
                                <div class="parcela-card">
                                    <span class="parcela-num">@p×</span>
                                    <span class="parcela-valor">R$ @valorParcela.ToString("N2")</span>
                                    <span class="parcela-destaque" style="color:@(p == 1 ? "var(--texto-faint)" : "var(--primario)")">
                                        @(p == 1 ? "À vista" : "Sem juros")
                                    </span>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <!-- FORMA DE PAGAMENTO -->
                <div class="admin-card" style="padding:1.5rem;margin-bottom:1.25rem">
                    <h3 style="margin-bottom:1.25rem;color:var(--primario);font-size:1rem">Forma de Pagamento</h3>
                    <div style="display:flex;gap:.75rem;flex-wrap:wrap" id="pagamentoOpcoes">

                        <label class="pagamento-opt pagamento-ativo" id="optCartao">
                            <input type="radio" name="formaPagamentoOpt" value="Cartão" checked onchange="selecionarPagamento('Cartão')" />
                            <span>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                                Cartão de Crédito
                            </span>
                        </label>

                        <label class="pagamento-opt" id="optPix">
                            <input type="radio" name="formaPagamentoOpt" value="Pix" onchange="selecionarPagamento('Pix')" />
                            <span>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                                Pix
                            </span>
                        </label>

                        <label class="pagamento-opt" id="optBoleto">
                            <input type="radio" name="formaPagamentoOpt" value="Boleto" onchange="selecionarPagamento('Boleto')" />
                            <span>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="6" y1="9" x2="6" y2="15"/><line x1="10" y1="9" x2="10" y2="15"/><line x1="14" y1="9" x2="14" y2="15"/><line x1="18" y1="9" x2="18" y2="15"/></svg>
                                Boleto
                            </span>
                        </label>
                    </div>

                    <!-- Info Pix (aparece ao selecionar) -->
                    <div id="infoPix" style="display:none;margin-top:1.25rem;padding:1rem;background:rgba(0,255,0,0.05);border:1px dashed var(--borda);border-radius:var(--radius)">
                        <p style="color:var(--primario);font-weight:600;margin-bottom:.5rem">Pagamento via Pix</p>
                        <p style="color:var(--texto-muted);font-size:.875rem">Após confirmar o pedido, você receberá o QR Code do Pix no e-mail informado. O prazo para pagamento é de <strong style="color:var(--texto)">30 minutos</strong>.</p>
                    </div>

                    <!-- Info Boleto (aparece ao selecionar) -->
                    <div id="infoBoleto" style="display:none;margin-top:1.25rem;padding:1rem;background:rgba(255,255,0,0.04);border:1px dashed var(--borda-cta);border-radius:var(--radius)">
                        <p style="color:var(--cta);font-weight:600;margin-bottom:.5rem">Pagamento via Boleto</p>
                        <p style="color:var(--texto-muted);font-size:.875rem">O boleto será enviado para seu e-mail. Prazo de vencimento: <strong style="color:var(--texto)">3 dias úteis</strong>. A liberação ocorre em até 2 dias após o pagamento.</p>
                    </div>
                </div>

                <button type="button" onclick="validarEProsseguir()"
                        class="btn btn-amarelo btn-grande" style="width:100%">
                    Confirmar Pedido — R$ @total.ToString("N2")
                </button>
            </form>
        </div>

        <!-- RESUMO -->
        <div class="checkout-resumo">
            <div class="admin-card" style="padding:1.5rem;position:sticky;top:4.5rem">
                <h3 style="margin-bottom:1rem;color:var(--primario);font-size:.95rem">Resumo do Pedido</h3>
                @foreach (var item in Model)
                {
                    <div class="resumo-item">
                        <div style="flex:1">
                            <span style="font-weight:600;font-size:.875rem;display:block">@item.Nome</span>
                            <span style="color:var(--texto-muted);font-size:.78rem">@item.Quantidade× R$ @item.ValorUnitario.ToString("N2")</span>
                        </div>
                        <span class="preco-atual" style="font-size:.9rem;flex-shrink:0">R$ @item.Subtotal.ToString("N2")</span>
                    </div>
                }
                <div style="border-top:1px solid var(--borda);margin-top:.75rem;padding-top:.75rem">
                    <div style="display:flex;justify-content:space-between;font-size:.875rem;color:var(--texto-muted);margin-bottom:.4rem">
                        <span>Subtotal</span><span>R$ @total.ToString("N2")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:.875rem;color:var(--texto-muted);margin-bottom:.75rem">
                        <span>Frete</span><span style="color:var(--primario)">Grátis</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-weight:700;color:var(--texto)">
                        <span>Total</span>
                        <span class="preco-atual" style="font-size:1.1rem">R$ @total.ToString("N2")</span>
                    </div>
                    <p style="color:var(--texto-faint);font-size:.77rem;margin-top:.4rem;text-align:right">
                        12x de R$ @((total / 12).ToString("N2")) sem juros
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     MODAL CARTÃO DE CRÉDITO
     ============================================================ -->
<div id="modalCartao" class="modal-overlay" style="display:none" onclick="fecharModalSeForaDoCard(event)">
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modalCartaoTitulo">

        <!-- Preview do cartão visual -->
        <div class="cartao-preview" id="cartaoPreview">
            <div class="cartao-chip">
                <svg width="32" height="24" viewBox="0 0 32 24"><rect width="32" height="24" rx="4" fill="#c8a84b" opacity=".9"/><rect x="10" y="4" width="12" height="16" rx="2" fill="none" stroke="rgba(0,0,0,0.3)" stroke-width="1"/><line x1="16" y1="4" x2="16" y2="20" stroke="rgba(0,0,0,0.3)"/><line x1="10" y1="12" x2="22" y2="12" stroke="rgba(0,0,0,0.3)"/></svg>
            </div>
            <div class="cartao-numero-preview" id="prevNumero">•••• •••• •••• ••••</div>
            <div class="cartao-info-preview">
                <div>
                    <div class="cartao-label-preview">Titular</div>
                    <div id="prevNome">NOME DO TITULAR</div>
                </div>
                <div>
                    <div class="cartao-label-preview">Validade</div>
                    <div id="prevValidade">MM/AA</div>
                </div>
                <div class="cartao-bandeira" id="prevBandeira">
                    <svg width="40" height="24" viewBox="0 0 40 24"><circle cx="15" cy="12" r="10" fill="#eb001b" opacity=".9"/><circle cx="25" cy="12" r="10" fill="#f79e1b" opacity=".9"/></svg>
                </div>
            </div>
        </div>

        <h3 id="modalCartaoTitulo" style="margin:1.25rem 0 1rem;font-size:1rem;color:var(--primario)">Dados do Cartão</h3>

        <div class="form-grupo">
            <label class="form-label">Número do Cartão *</label>
            <input type="text" id="cartaoNumero" class="form-input" placeholder="0000 0000 0000 0000"
                   maxlength="19" inputmode="numeric" oninput="formatarNumeroCartao(this)" />
            <span class="campo-erro" id="erroCartaoNumero"></span>
        </div>

        <div class="form-grupo">
            <label class="form-label">Nome no Cartão *</label>
            <input type="text" id="cartaoNome" class="form-input" placeholder="NOME CONFORME NO CARTÃO"
                   oninput="this.value=this.value.toUpperCase(); document.getElementById('prevNome').textContent=this.value||'NOME DO TITULAR'" />
            <span class="campo-erro" id="erroCartaoNome"></span>
        </div>

        <div class="form-grid-2" style="gap:.75rem">
            <div class="form-grupo">
                <label class="form-label">Validade *</label>
                <input type="text" id="cartaoValidade" class="form-input" placeholder="MM/AA"
                       maxlength="5" inputmode="numeric" oninput="formatarValidade(this)" />
                <span class="campo-erro" id="erroCartaoValidade"></span>
            </div>
            <div class="form-grupo">
                <label class="form-label">CVV *</label>
                <input type="text" id="cartaoCvv" class="form-input" placeholder="•••"
                       maxlength="4" inputmode="numeric"
                       oninput="this.value=this.value.replace(/\D/g,'')" />
                <span class="campo-erro" id="erroCartaoCvv"></span>
            </div>
        </div>

        <div style="display:flex;gap:.75rem;margin-top:1.25rem">
            <button type="button" onclick="fecharModal()" class="btn btn-outline" style="flex:1">Cancelar</button>
            <button type="button" onclick="confirmarCartao()" class="btn btn-amarelo" style="flex:1">Confirmar Pagamento</button>
        </div>
    </div>
</div>

@section Styles {
<style>
/* ---- Erros de campo ---- */
.campo-erro {
    color: #ff5252;
    font-size: .78rem;
    margin-top: .2rem;
    display: block;
    min-height: 1rem;
}
.form-input.invalido { border-color: #ff5252 !important; box-shadow: 0 0 0 3px rgba(255,82,82,0.12) !important; }
.form-input.valido   { border-color: var(--primario) !important; }

/* ---- Modal overlay ---- */
.modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(4px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
}
.modal-card {
    background: #1a0040;
    border: 1px solid var(--borda);
    border-radius: var(--radius-xl);
    padding: 1.75rem;
    width: 100%;
    max-width: 440px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 64px rgba(0,0,0,0.7), 0 0 40px rgba(0,255,0,0.06);
    animation: modalEntrada .25s ease;
}
@@keyframes modalEntrada {
    from { opacity:0; transform: translateY(20px) scale(.97); }
    to   { opacity:1; transform: none; }
}

/* ---- Preview cartão ---- */
.cartao-preview {
    background: linear-gradient(135deg, #1a0040 0%, #0d0020 50%, #1a0060 100%);
    border: 1px solid rgba(0,255,0,0.25);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    color: #fff;
    font-family: 'Orbitron', monospace;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 20px rgba(0,255,0,0.08);
    position: relative;
    overflow: hidden;
}
.cartao-preview::before {
    content: '';
    position: absolute;
    top: -30px; right: -30px;
    width: 120px; height: 120px;
    border-radius: 50%;
    background: rgba(0,255,0,0.04);
}
.cartao-chip { margin-bottom: 1rem; }
.cartao-numero-preview {
    font-size: 1.1rem;
    letter-spacing: .18em;
    margin-bottom: 1.25rem;
    color: rgba(255,255,255,0.9);
}
.cartao-info-preview {
    display: flex;
    gap: 1.5rem;
    align-items: flex-end;
    font-size: .78rem;
}
.cartao-label-preview {
    color: rgba(255,255,255,0.45);
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    margin-bottom: .2rem;
}
.cartao-bandeira { margin-left: auto; }
</style>
}

@section Scripts {
<script>
// ================================================================
// VALIDAÇÕES
// ================================================================

function validarEmail(email) {
    return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email.trim());
}

function validarTelefone(tel) {
    // Aceita (XX) 9 XXXX-XXXX ou (XX) XXXX-XXXX
    const digits = tel.replace(/\D/g,'');
    return digits.length === 10 || digits.length === 11;
}

function mostrarErro(id, msg) {
    const el = document.getElementById(id);
    if (el) el.textContent = msg;
}
function limparErro(id) {
    const el = document.getElementById(id);
    if (el) el.textContent = '';
}

function setEstado(inputId, valido) {
    const input = document.getElementById(inputId);
    if (!input) return;
    input.classList.toggle('invalido', !valido);
    input.classList.toggle('valido',   valido);
}

// ---- Máscara Telefone em tempo real ----
document.getElementById('telefone')?.addEventListener('input', function() {
    let v = this.value.replace(/\D/g,'').slice(0,11);
    if (v.length > 10) v = v.replace(/^(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3');
    else if (v.length > 6) v = v.replace(/^(\d{2})(\d{4})(\d*)$/, '($1) $2-$3');
    else if (v.length > 2) v = v.replace(/^(\d{2})(\d*)$/, '($1) $2');
    this.value = v;
});

// ---- Máscara CEP ----
document.getElementById('cep')?.addEventListener('input', async function() {
    let v = this.value.replace(/\D/g,'').slice(0,8);
    if (v.length > 5) v = v.replace(/^(\d{5})(\d*)$/, '$1-$2');
    this.value = v;
    if (v.replace(/\D/g,'').length === 8) {
        try {
            const r = await fetch(`https://viacep.com.br/ws/${v.replace(/\D/g,'')}/json/`);
            const d = await r.json();
            if (!d.erro) {
                document.getElementById('endereco').value =
                    `${d.logradouro}, ${d.bairro} — ${d.localidade}/${d.uf}`;
            }
        } catch(e) {}
    }
});

// ---- Validar e prosseguir ----
function validarEProsseguir() {
    let ok = true;

    // Nome
    const nome = document.getElementById('nome').value.trim();
    if (nome.length < 3) {
        mostrarErro('erroNome', 'Informe seu nome completo.');
        setEstado('nome', false); ok = false;
    } else {
        limparErro('erroNome'); setEstado('nome', true);
    }

    // Email
    const email = document.getElementById('email').value.trim();
    if (!validarEmail(email)) {
        mostrarErro('erroEmail', 'Informe um e-mail válido.');
        setEstado('email', false); ok = false;
    } else {
        limparErro('erroEmail'); setEstado('email', true);
    }

    // Telefone
    const tel = document.getElementById('telefone').value.trim();
    if (!validarTelefone(tel)) {
        mostrarErro('erroTelefone', 'Informe um telefone válido com DDD. Ex: (14) 9 9999-9999');
        setEstado('telefone', false); ok = false;
    } else {
        limparErro('erroTelefone'); setEstado('telefone', true);
    }

    // Endereço
    const end = document.getElementById('endereco').value.trim();
    if (end.length < 5) {
        mostrarErro('erroEndereco', 'Informe o endereço completo.');
        setEstado('endereco', false); ok = false;
    } else {
        limparErro('erroEndereco'); setEstado('endereco', true);
    }

    if (!ok) {
        // Rolar para o primeiro erro
        document.querySelector('.form-input.invalido')?.scrollIntoView({ behavior:'smooth', block:'center' });
        return;
    }

    // Verifica forma de pagamento
    const formaPag = document.querySelector('input[name="formaPagamentoOpt"]:checked')?.value ?? 'Cartão';
    document.getElementById('formaPagamentoHidden').value = formaPag;

    if (formaPag === 'Cartão') {
        abrirModalCartao();
    } else {
        document.getElementById('formCheckout').submit();
    }
}

// ================================================================
// FORMA DE PAGAMENTO
// ================================================================

function selecionarPagamento(forma) {
    document.getElementById('infoPix').style.display    = forma === 'Pix'    ? 'block' : 'none';
    document.getElementById('infoBoleto').style.display = forma === 'Boleto' ? 'block' : 'none';
    document.getElementById('formaPagamentoHidden').value = forma;
}

// ================================================================
// MODAL CARTÃO
// ================================================================

function abrirModalCartao() {
    document.getElementById('modalCartao').style.display = 'flex';
    document.body.style.overflow = 'hidden';
    document.getElementById('cartaoNumero').focus();
}

function fecharModal() {
    document.getElementById('modalCartao').style.display = 'none';
    document.body.style.overflow = '';
}

function fecharModalSeForaDoCard(e) {
    if (e.target === document.getElementById('modalCartao')) fecharModal();
}

// Fecha com ESC
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') fecharModal();
});

// ---- Formatar número do cartão ----
function formatarNumeroCartao(input) {
    let v = input.value.replace(/\D/g,'').slice(0,16);
    v = v.replace(/(.{4})/g, '$1 ').trim();
    input.value = v;
    // atualiza preview
    const preview = v || '•••• •••• •••• ••••';
    const exibe = v.length < 19
        ? v.padEnd(19, '•').replace(/[^•\s]/g, d => d)
        : v;
    document.getElementById('prevNumero').textContent =
        v.length > 0 ? v.padEnd(19, '•') : '•••• •••• •••• ••••';

    // detectar bandeira simples
    const raw = v.replace(/\s/g,'');
    const bandEl = document.getElementById('prevBandeira');
    if (/^4/.test(raw)) {
        bandEl.innerHTML = '<svg width="40" height="24" viewBox="0 0 40 24"><text x="2" y="18" fill="#1a1f71" font-size="16" font-weight="900" font-family="sans-serif">VISA</text></svg>';
    } else if (/^5[1-5]/.test(raw) || /^2[2-7]/.test(raw)) {
        bandEl.innerHTML = '<svg width="40" height="24" viewBox="0 0 40 24"><circle cx="15" cy="12" r="10" fill="#eb001b" opacity=".9"/><circle cx="25" cy="12" r="10" fill="#f79e1b" opacity=".9"/></svg>';
    } else if (/^3[47]/.test(raw)) {
        bandEl.innerHTML = '<svg width="40" height="24" viewBox="0 0 40 24"><rect x="1" y="3" width="38" height="18" rx="3" fill="#2557d6"/><text x="5" y="17" fill="white" font-size="9" font-family="sans-serif">AMEX</text></svg>';
    } else {
        bandEl.innerHTML = '<svg width="40" height="24" viewBox="0 0 40 24"><circle cx="15" cy="12" r="10" fill="#eb001b" opacity=".9"/><circle cx="25" cy="12" r="10" fill="#f79e1b" opacity=".9"/></svg>';
    }
}

// ---- Formatar validade ----
function formatarValidade(input) {
    let v = input.value.replace(/\D/g,'').slice(0,4);
    if (v.length > 2) v = v.slice(0,2) + '/' + v.slice(2);
    input.value = v;
    document.getElementById('prevValidade').textContent = v || 'MM/AA';
}

// ---- Confirmar cartão ----
function confirmarCartao() {
    let ok = true;

    const num = document.getElementById('cartaoNumero').value.replace(/\s/g,'');
    if (num.length < 13 || num.length > 16 || !/^\d+$/.test(num)) {
        mostrarErro('erroCartaoNumero', 'Número de cartão inválido.'); ok = false;
    } else { limparErro('erroCartaoNumero'); }

    const nome = document.getElementById('cartaoNome').value.trim();
    if (nome.length < 3) {
        mostrarErro('erroCartaoNome', 'Informe o nome do titular.'); ok = false;
    } else { limparErro('erroCartaoNome'); }

    const val = document.getElementById('cartaoValidade').value;
    const [mm, aa] = val.split('/');
    const mesValido = mm && parseInt(mm) >= 1 && parseInt(mm) <= 12;
    const anoValido = aa && parseInt(aa) >= 25;
    if (!mesValido || !anoValido) {
        mostrarErro('erroCartaoValidade', 'Validade inválida. Use MM/AA.'); ok = false;
    } else { limparErro('erroCartaoValidade'); }

    const cvv = document.getElementById('cartaoCvv').value;
    if (cvv.length < 3) {
        mostrarErro('erroCartaoCvv', 'CVV inválido.'); ok = false;
    } else { limparErro('erroCartaoCvv'); }

    if (!ok) return;

    fecharModal();
    document.getElementById('formaPagamentoHidden').value = 'Cartão';
    document.getElementById('formCheckout').submit();
}
</script>
}
