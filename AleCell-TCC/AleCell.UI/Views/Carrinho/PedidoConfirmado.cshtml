@{
    ViewData["Title"] = "Pedido Confirmado";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var numeroPedido = TempData["NumeroPedido"]?.ToString() ?? "—";
    var parcelas     = TempData["Parcelas"]?.ToString() ?? "1";
}

<section class="container">
    <div class="pedido-confirmado">
        <div class="confirmado-icon">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--primario)" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="9 12 11 14 15 10"/>
            </svg>
        </div>
        <h1 style="color:var(--primario);font-family:'Orbitron',sans-serif;margin:.75rem 0">Pedido Confirmado!</h1>
        <p style="color:var(--texto-muted);font-size:1.05rem">Obrigado pela sua compra na AleCell.</p>

        <div class="admin-card" style="padding:1.5rem;margin:1.5rem auto;max-width:480px;text-align:left">
            <div class="resumo-linha">
                <span>Número do Pedido</span>
                <span style="color:var(--primario);font-family:'Orbitron',sans-serif;font-weight:700">#@numeroPedido</span>
            </div>
            <div class="resumo-linha">
                <span>Parcelamento</span>
                <span>@parcelas× sem juros</span>
            </div>
            <div class="resumo-linha">
                <span>Entrega</span>
                <span>Grátis — 3 a 7 dias úteis</span>
            </div>
            <div class="resumo-linha">
                <span>Status</span>
                <span style="color:var(--primario)">Aguardando confirmação</span>
            </div>
        </div>

        <p style="color:var(--texto-muted);font-size:.9rem;margin-bottom:1.5rem">
            Você receberá atualizações pelo e-mail cadastrado.<br />
            Em caso de dúvidas, entre em contato: <strong style="color:var(--primario)">+55 (14) 99805-7715</strong>
        </p>

        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
            <a asp-controller="Home" asp-action="Catalogo" class="btn">Continuar Comprando</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline">Voltar ao Início</a>
        </div>
    </div>
</section>
