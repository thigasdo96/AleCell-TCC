@model List<ProdutoDto>
@{
    ViewData["Title"] = "Meu Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string nome   = ViewBag.Nome   ?? "Usuário";
    string email  = ViewBag.Email  ?? "";
    string foto   = ViewBag.Foto   ?? "";
    string perfil = ViewBag.Perfil ?? "Cliente";
    string inicial = nome.Length > 0 ? nome[0].ToString().ToUpper() : "U";
}

<section class="container">
    <div class="page-header">
        <h1 class="page-titulo">Meu Perfil</h1>
    </div>

    <div class="perfil-layout">

        <!-- CARTÃO DO USUÁRIO -->
        <div class="perfil-sidebar">
            <div class="admin-card" style="padding:2rem;text-align:center">
                <div class="perfil-avatar">
                    @if (!string.IsNullOrEmpty(foto))
                    {
                        <img src="@foto" alt="@nome" class="perfil-foto" />
                    }
                    else
                    {
                        <div class="perfil-inicial">@inicial</div>
                    }
                </div>
                <h2 class="perfil-nome">@nome</h2>
                <p style="color:var(--texto-muted);font-size:.9rem">@email</p>
                <div class="perfil-badge @(perfil == "Administrador" ? "badge-admin" : "badge-cliente")">
                    @perfil
                </div>
            </div>

            <div class="admin-card" style="padding:1.25rem;margin-top:1rem">
                <h4 style="color:var(--primario);margin-bottom:.75rem">Ações Rápidas</h4>
                <div style="display:flex;flex-direction:column;gap:.5rem">
                    <a asp-controller="Carrinho" asp-action="Index" class="btn btn-outline" style="text-align:center">
                        Ver Carrinho
                    </a>
                    <a asp-controller="Home" asp-action="Catalogo" class="btn" style="text-align:center">
                        Comprar Agora
                    </a>
                    @if (perfil == "Administrador")
                    {
                        <a asp-controller="Admin" asp-action="Index" class="btn btn-amarelo" style="text-align:center">
                            Painel Admin
                        </a>
                    }
                    <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline" style="text-align:center;color:#ff5252;border-color:#ff5252">
                        Sair da Conta
                    </a>
                </div>
            </div>
        </div>

        <!-- CONTEÚDO PRINCIPAL -->
        <div class="perfil-conteudo">

            <!-- INFO DA CONTA -->
            <div class="admin-card" style="padding:1.5rem;margin-bottom:1.25rem">
                <h3 style="color:var(--primario);margin-bottom:1.25rem">Informações da Conta</h3>
                <div class="form-grid-2">
                    <div class="form-grupo">
                        <label class="form-label">Nome</label>
                        <div class="form-input-readonly">@nome</div>
                    </div>
                    <div class="form-grupo">
                        <label class="form-label">E-mail</label>
                        <div class="form-input-readonly">@email</div>
                    </div>
                    <div class="form-grupo">
                        <label class="form-label">Tipo de Conta</label>
                        <div class="form-input-readonly">@perfil</div>
                    </div>
                    <div class="form-grupo">
                        <label class="form-label">Status</label>
                        <div class="form-input-readonly" style="color:var(--primario)">Conta Ativa</div>
                    </div>
                </div>
            </div>

            <!-- ÚLTIMOS 2 PEDIDOS -->
            <div class="admin-card" style="padding:1.5rem">
                <div class="admin-card-header" style="margin-bottom:1.25rem">
                    <h3 style="color:var(--primario)">Últimas Compras</h3>
                    <a asp-controller="Home" asp-action="Catalogo" class="btn" style="padding:.4rem .8rem;font-size:.82rem">Ver Catálogo</a>
                </div>

                @if (Model != null && Model.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:1rem">
                        @foreach (var prod in Model)
                        {
                            <div class="pedido-item">
                                <div class="pedido-item-foto">
                                    @if (!string.IsNullOrEmpty(prod.Foto))
                                    {
                                        <img src="@prod.Foto" alt="@prod.Nome" />
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 48 60" width="44" height="55" xmlns="http://www.w3.org/2000/svg">
                                            <rect x="3" y="2" width="42" height="56" rx="6" fill="#1a0040" stroke="rgba(0,255,0,0.2)" stroke-width="1.5"/>
                                            <rect x="7" y="9" width="34" height="40" rx="3" fill="#0d0020"/>
                                            <circle cx="24" cy="55" r="2.5" fill="rgba(0,255,0,0.25)"/>
                                            <rect x="18" y="4" width="12" height="1.5" rx=".75" fill="rgba(0,255,0,0.15)"/>
                                        </svg>
                                    }
                                </div>
                                <div class="pedido-item-info">
                                    <strong>@prod.Nome</strong>
                                    <span style="color:var(--texto-muted);font-size:.83rem">@prod.CategoriaNome</span>
                                    <span class="preco-atual" style="font-size:.95rem">R$ @prod.ValorVenda.ToString("N2")</span>
                                </div>
                                <div class="pedido-item-status">
                                    <span class="em-estoque" style="font-size:.78rem;padding:.2rem .6rem;border-radius:4px;background:rgba(0,255,0,0.1)">Entregue</span>
                                    <a asp-controller="Home" asp-action="Produto" asp-route-id="@prod.Id"
                                       class="btn btn-outline" style="padding:.3rem .6rem;font-size:.78rem;margin-top:.4rem">
                                        Comprar de Novo
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding:2rem 0">
                        <p>Você ainda não fez nenhuma compra.</p>
                        <a asp-controller="Home" asp-action="Catalogo" class="btn">Explorar Produtos</a>
                    </div>
                }
            </div>

        </div>
    </div>
</section>
