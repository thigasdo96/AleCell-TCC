<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ALECELL — @ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/alecell.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar">
        <a asp-controller="Home" asp-action="Index" class="logo">ALECELL</a>
        <button class="menu-toggle" id="menuToggle" aria-label="Abrir menu">&#9776;</button>
        <ul class="nav-links" id="navLinks">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Home" asp-action="Catalogo">Catálogo</a></li>
            <li><a asp-controller="Home" asp-action="Conserto">Conserto</a></li>
            <li><a asp-controller="Home" asp-action="Mapa">Nossa Loja</a></li>
            <li>
                <a asp-controller="Carrinho" asp-action="Index" class="nav-carrinho" title="Carrinho">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    Carrinho
                </a>
            </li>
            <li class="nav-auth">
                <partial name="_LoginPartial" />
            </li>
        </ul>
    </nav>

    <main>
        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-erro">@TempData["Erro"]</div>
        }
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-sucesso">@TempData["Sucesso"]</div>
        }
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-brand">
                <span class="logo">ALECELL</span>
                <p>Loja especializada em celulares Apple e Xiaomi.<br />Qualidade e tecnologia ao seu alcance.</p>
            </div>
            <div class="footer-links">
                <h4>Navegação</h4>
                <ul>
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="Catalogo">Catálogo</a></li>
                    <li><a asp-controller="Home" asp-action="Conserto">Conserto</a></li>
                    <li><a asp-controller="Home" asp-action="Mapa">Nossa Loja</a></li>
                    <li><a asp-controller="Carrinho" asp-action="Index">Carrinho</a></li>
                </ul>
            </div>
            <div class="footer-contato">
                <h4>Contato</h4>
                <p>R. Antonio Eurico Dias Batista<br />Colina da Barra<br />Barra Bonita — SP, 17340-506</p>
                <p style="margin-top:.5rem">
                    <a href="tel:+5514998057715" style="color:var(--texto-muted)">+55 (14) 99805-7715</a>
                </p>
                <p>Todos os dias: 09h às 21h</p>
                <p style="margin-top:.5rem">
                    <a href="https://www.google.com/maps/place/Alecellapple/data=!4m2!3m1!1s0x0:0xc9dc7bedbfad89a3?sa=X&ved=1t:2428&ictx=111"
                       target="_blank" style="color:var(--primario);font-size:.82rem">
                        Ver no Google Maps ↗
                    </a>
                </p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2025 ALECELL — Todos os direitos reservados.</p>
        </div>
    </footer>

    <script src="~/js/alecell.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
