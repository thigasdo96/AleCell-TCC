@model ProdutoDto
@{
    ViewData["Title"] = Model.Nome;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <nav class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>›</span>
        <a asp-controller="Home" asp-action="Catalogo">Catálogo</a>
        <span>›</span>
        <span>@Model.Nome</span>
    </nav>

    <div class="produto-detalhe-grid">
        <!-- IMAGEM -->
        <div class="produto-detalhe-foto">
            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <img src="@Model.Foto" alt="@Model.Nome" />
            }
            else
            {
                <div class="produto-imagem-placeholder grande">
                    <svg viewBox="0 0 120 160" width="120" height="160" xmlns="http://www.w3.org/2000/svg">
                        <rect x="8" y="4" width="104" height="152" rx="12" fill="#1a0040" stroke="rgba(0,255,0,0.3)" stroke-width="2"/>
                        <rect x="16" y="22" width="88" height="112" rx="5" fill="#0d0020"/>
                        <circle cx="60" cy="146" r="5.5" fill="rgba(0,255,0,0.3)"/>
                        <rect x="44" y="8" width="32" height="4" rx="2" fill="rgba(0,255,0,0.2)"/>
                        <circle cx="82" cy="10" r="3" fill="rgba(0,255,0,0.15)"/>
                        <rect x="24" y="38" width="72" height="2" rx="1" fill="rgba(0,255,0,0.15)"/>
                        <rect x="24" y="50" width="55" height="2" rx="1" fill="rgba(0,255,0,0.1)"/>
                        <rect x="24" y="62" width="65" height="2" rx="1" fill="rgba(0,255,0,0.1)"/>
                        <rect x="24" y="74" width="45" height="2" rx="1" fill="rgba(0,255,0,0.08)"/>
                    </svg>
                </div>
            }
        </div>

        <!-- INFO -->
        <div class="produto-detalhe-info">
            @if (!string.IsNullOrEmpty(Model.CategoriaNome))
            {
                <div class="produto-categoria-tag">@Model.CategoriaNome</div>
            }
            @if (Model.Destaque)
            {
                <div class="produto-destaque-badge">Produto em Destaque</div>
            }

            <h1 class="produto-detalhe-nome">@Model.Nome</h1>

            <div class="produto-detalhe-preco">
                <span class="preco-atual grande">R$ @Model.ValorVenda.ToString("N2")</span>
                <span class="preco-parcelado">ou 12x de R$ @((Model.ValorVenda / 12).ToString("N2")) sem juros</span>
            </div>

            <div class="@(Model.Qtde > 0 ? "em-estoque" : "sem-estoque") grande" style="font-size:1rem;margin-bottom:1rem">
                @(Model.Qtde > 0 ? $"{Model.Qtde} unidades em estoque" : "Produto indisponível")
            </div>

            @if (!string.IsNullOrEmpty(Model.Descricao))
            {
                <div class="produto-detalhe-descricao">
                    <h3>Descrição</h3>
                    <p>@Model.Descricao</p>
                </div>
            }

            <div class="produto-acoes grande">
                @if (Model.Qtde > 0)
                {
                    <a asp-controller="Carrinho" asp-action="Adicionar" asp-route-id="@Model.Id" class="btn btn-grande">
                        Adicionar ao Carrinho
                    </a>
                    <a asp-controller="Carrinho" asp-action="ComprarAgora" asp-route-id="@Model.Id" class="btn btn-amarelo btn-grande">
                        Comprar Agora
                    </a>
                }
                else
                {
                    <button class="btn btn-grande" disabled style="opacity:.45;cursor:not-allowed">Indisponível</button>
                }
                <a asp-controller="Home" asp-action="Catalogo" class="btn btn-outline">Continuar comprando</a>
            </div>

            <div class="produto-garantias">
                <div class="garantia-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    <span>Frete Grátis</span>
                </div>
                <div class="garantia-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span>Garantia Oficial</span>
                </div>
                <div class="garantia-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                    <span>7 dias para troca</span>
                </div>
                <div class="garantia-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    <span>12x sem juros</span>
                </div>
            </div>
        </div>
    </div>
</section>
