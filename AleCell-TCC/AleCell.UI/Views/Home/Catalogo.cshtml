@model List<ProdutoDto>
@{
    ViewData["Title"] = "Catálogo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container">
    <div class="page-header">
        <div>
            <h1 class="page-titulo">Catálogo</h1>
            <p class="page-desc">Encontre o celular perfeito para você</p>
        </div>
    </div>

    <!-- BARRA DE PESQUISA -->
    <div class="busca-catalogo-wrap">
        <div class="busca-catalogo-inner">
            <svg class="busca-catalogo-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
                type="text"
                id="buscaCatalogo"
                class="busca-catalogo-input"
                placeholder="Pesquisar produto..."
                autocomplete="off"
                oninput="filtrarProdutos()"
            />
            <button class="busca-catalogo-clear" id="btnLimparBusca" onclick="limparBusca()" title="Limpar pesquisa" style="display:none">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
    </div>

    <div class="filtros-bar">
        <a asp-controller="Home" asp-action="Catalogo"
           class="filtro-btn @(ViewBag.CategoriaSelecionada == 0 ? "ativo" : "")">Todos</a>
        @foreach (var cat in (List<CategoriaDto>)ViewBag.Categorias)
        {
            <a asp-controller="Home" asp-action="Catalogo" asp-route-categoriaId="@cat.Id"
               class="filtro-btn @(ViewBag.CategoriaSelecionada == cat.Id ? "ativo" : "")"
               style="@(ViewBag.CategoriaSelecionada == cat.Id ? $"border-color:{cat.Cor};color:{cat.Cor};background:rgba(0,255,0,0.07)" : "")">
                @cat.Nome
            </a>
        }
    </div>

    <p class="catalogo-count" id="catalogoCount">@Model.Count produto(s) encontrado(s)</p>

    @if (Model.Any())
    {
        <div class="produtos-grid" id="produtosGrid">
            @foreach (var prod in Model)
            {
                <div class="produto-card" data-nome="@prod.Nome.ToLower()" data-desc="@(prod.Descricao?.ToLower() ?? "")">
                    @if (!string.IsNullOrEmpty(prod.CategoriaNome))
                    {
                        <div class="produto-marca-badge">@prod.CategoriaNome</div>
                    }
                    @if (prod.Destaque)
                    {
                        <div class="produto-destaque-badge" style="position:absolute;top:.65rem;right:.65rem;z-index:1">Destaque</div>
                    }

                    @if (!string.IsNullOrEmpty(prod.Foto))
                    {
                        <img src="@prod.Foto" alt="@prod.Nome" class="produto-imagem" />
                    }
                    else
                    {
                        <div class="produto-imagem-placeholder">
                            <svg width="90" height="150" viewBox="0 0 90 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="8" y="5" width="74" height="140" rx="11" fill="#1a0040" stroke="rgba(0,255,0,0.3)" stroke-width="1.5"/>
                                <rect x="14" y="18" width="62" height="104" rx="4" fill="#0d0020"/>
                                <rect x="32" y="7" width="26" height="5" rx="2.5" fill="rgba(0,255,0,0.15)"/>
                                <circle cx="55" cy="9.5" r="2" fill="rgba(0,255,0,0.25)"/>
                                <circle cx="45" cy="135" r="4" fill="rgba(0,255,0,0.15)" stroke="rgba(0,255,0,0.3)" stroke-width="1"/>
                                <rect x="20" y="38" width="50" height="2" rx="1" fill="rgba(0,255,0,0.15)"/>
                                <rect x="20" y="46" width="36" height="2" rx="1" fill="rgba(0,255,0,0.09)"/>
                                <rect x="20" y="54" width="44" height="2" rx="1" fill="rgba(0,255,0,0.09)"/>
                                <text x="45" y="95" text-anchor="middle" font-size="28" fill="rgba(0,255,0,0.2)" font-family="sans-serif">📱</text>
                            </svg>
                        </div>
                    }

                    <div class="produto-info">
                        <h3 class="produto-nome">@prod.Nome</h3>
                        @if (!string.IsNullOrEmpty(prod.Descricao))
                        {
                            <p class="produto-desc">@(prod.Descricao.Length > 80 ? prod.Descricao[..80] + "…" : prod.Descricao)</p>
                        }
                        <div class="produto-preco">
                            <span class="preco-atual">R$ @prod.ValorVenda.ToString("N2")</span>
                        </div>
                        <p class="produto-parcela">12x de R$ @((prod.ValorVenda / 12).ToString("N2")) sem juros</p>
                        <div class="@(prod.Qtde > 0 ? "em-estoque" : "sem-estoque")">
                            @(prod.Qtde > 0 ? $"{prod.Qtde} em estoque" : "Indisponível")
                        </div>
                        <div class="produto-acoes">
                            <a asp-controller="Home" asp-action="Produto" asp-route-id="@prod.Id" class="btn">Ver</a>
                            @if (prod.Qtde > 0)
                            {
                                <a asp-controller="Carrinho" asp-action="Adicionar" asp-route-id="@prod.Id"
                                   class="btn btn-amarelo" title="Adicionar ao Carrinho">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                                    </svg>
                                    Comprar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="empty-state" id="semResultados" style="display:none">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.3;margin-bottom:.75rem">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <p>Nenhum produto encontrado para "<span id="termoBusca"></span>".</p>
            <button onclick="limparBusca()" class="btn btn-outline" style="margin-top:.5rem">Limpar pesquisa</button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>Nenhum produto encontrado nessa categoria.</p>
            <a asp-controller="Home" asp-action="Catalogo" class="btn">Ver Todos</a>
        </div>
    }
</section>

@section Scripts {
<script>
const totalInicial = @Model.Count;

function filtrarProdutos() {
    const termo = document.getElementById('buscaCatalogo').value.toLowerCase().trim();
    const cards = document.querySelectorAll('#produtosGrid .produto-card');
    const btnLimpar = document.getElementById('btnLimparBusca');
    const semResultados = document.getElementById('semResultados');
    const count = document.getElementById('catalogoCount');
    const grid = document.getElementById('produtosGrid');

    btnLimpar.style.display = termo ? 'flex' : 'none';

    let visiveis = 0;
    cards.forEach(card => {
        const nome = card.dataset.nome || '';
        const desc = card.dataset.desc || '';
        const match = !termo || nome.includes(termo) || desc.includes(termo);
        card.style.display = match ? '' : 'none';
        if (match) visiveis++;
    });

    if (termo && visiveis === 0) {
        grid.style.display = 'none';
        semResultados.style.display = 'flex';
        document.getElementById('termoBusca').textContent = termo;
        count.textContent = '0 produto(s) encontrado(s)';
    } else {
        grid.style.display = '';
        semResultados.style.display = 'none';
        count.textContent = visiveis + ' produto(s) encontrado(s)';
    }
}

function limparBusca() {
    document.getElementById('buscaCatalogo').value = '';
    filtrarProdutos();
    document.getElementById('buscaCatalogo').focus();
}
</script>
}
