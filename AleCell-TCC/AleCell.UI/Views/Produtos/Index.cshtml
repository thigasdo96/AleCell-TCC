@model List<ProdutoVM>
@{
    ViewData["Title"] = "Produtos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Menu = "Produtos";
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-titulo">Produtos</h1>
        <p class="admin-subtitulo">Gerencie o catálogo da loja</p>
    </div>
    <a asp-action="Create" class="btn">+ Novo Produto</a>
</div>

@if (Model.Any())
{
    <div class="admin-card" style="padding:0;overflow:hidden">
        <div class="tabela-wrapper">
            <table class="tabela">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Foto</th>
                        <th>Nome</th>
                        <th>Categoria</th>
                        <th>Estoque</th>
                        <th>Preço</th>
                        <th>Destaque</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td style="color:var(--texto-faint);font-size:.78rem">@p.Id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.FotoUrl))
                                {
                                    <img src="@p.FotoUrl" alt="@p.Nome"
                                         style="width:44px;height:44px;object-fit:cover;border-radius:var(--radius);border:1px solid var(--borda)" />
                                }
                                else
                                {
                                    <div style="width:44px;height:44px;background:var(--fundo-card-hover);border-radius:var(--radius);border:1px solid var(--borda);display:flex;align-items:center;justify-content:center">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--texto-faint)" stroke-width="1.5">
                                            <rect x="5" y="2" width="14" height="20" rx="3"/>
                                            <circle cx="12" cy="17" r="1"/>
                                        </svg>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong style="color:var(--texto)">@p.Nome</strong>
                                @if (!string.IsNullOrEmpty(p.Descricao))
                                {
                                    <br /><small style="color:var(--texto-faint)">@(p.Descricao.Length > 55 ? p.Descricao[..55] + "…" : p.Descricao)</small>
                                }
                            </td>
                            <td>
                                <span style="background:var(--primario-bg);color:var(--primario);padding:.18rem .55rem;border-radius:4px;font-size:.75rem;font-weight:600">@p.CategoriaNome</span>
                            </td>
                            <td>
                                <span style="color:@(p.Qtde > 5 ? "var(--primario)" : p.Qtde > 0 ? "var(--cta)" : "#ff5252");font-weight:700;font-family:'Orbitron',sans-serif;font-size:.88rem">@p.Qtde</span>
                            </td>
                            <td>
                                <strong style="color:var(--texto);font-family:'Orbitron',sans-serif;font-size:.85rem">R$ @p.ValorVenda.ToString("N2")</strong>
                            </td>
                            <td style="text-align:center">
                                @if (p.Destaque)
                                {
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--cta)" stroke="var(--cta)" stroke-width="1">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                    </svg>
                                }
                                else
                                {
                                    <span style="color:var(--texto-faint)">—</span>
                                }
                            </td>
                            <td>
                                <div class="acoes-tabela">
                                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn" style="padding:.32rem .65rem;font-size:.78rem">
                                        Editar
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-danger" style="padding:.32rem .65rem;font-size:.78rem"
                                       onclick="return confirm('Excluir @p.Nome?')">
                                        Excluir
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div style="padding:.85rem 1rem;border-top:1px solid var(--borda);color:var(--texto-faint);font-size:.8rem">
            @Model.Count produto(s) cadastrado(s)
        </div>
    </div>
}
else
{
    <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--texto-faint)" stroke-width="1">
            <rect x="5" y="2" width="14" height="20" rx="3"/><circle cx="12" cy="17" r="1"/>
        </svg>
        <p>Nenhum produto cadastrado.</p>
        <a asp-action="Create" class="btn">+ Cadastrar Primeiro Produto</a>
    </div>
}
